#!/usr/bin/env bash
#
# argivo - interpreter for argivo scripts
#
# This script serves as a runtime interpreter that turns
# shell functions defined in a user-provided script into CLI commands.

set -Eeuo pipefail

# Check whether the user provided arguments
if (($# == 0)); then
    echo "error: no arguments were provided" >&2
    echo "usage: $0 <script> [args...]" >&2
    exit 1
fi

# Directory for argivo libraries
argivo_lib="/usr/local/lib/argivo"

# Check library directory
if [[ ! -d "$argivo_lib" ]]; then
    echo "error: library directory not found: $argivo_lib" >&2
    exit 1
fi

# Required libraries
declare -a argivo_libraries=(
    "annotations.bash"
    "properties.bash"
    "checker.bash"
    "help.bash"
)

# Libraries for argivo
for lib in "${argivo_libraries[@]}"; do
    file="$argivo_lib/$lib"

    if [[ ! -e "$file" ]]; then
        echo "error: required library not found: $file" >&2
        exit 1
    fi

    if [[ ! -r "$file" ]]; then
        echo "error: library is not readable: $file" >&2
        exit 1
    fi

    # shellcheck source=/dev/null
    source "$file"
done

# The interpreter includes built-in commands
# that can be used without a user script
case "$1" in
    --version|-v)
        argivo::version
        exit 0
        ;;

    --about|-a)
        argivo::about
        exit 0
        ;;

    --help|-h)
        argivo::help
        exit 0
        ;;

    --check|-c)
        shift
        argivo::check "$@" --verbose
        exit 0
        ;;
esac

# Get the script to be interpreted
script="$1"
shift

# Check that the script exists
if [[ ! -f "$script" ]]; then
    echo "error: script not found: $script"
    exit 1
fi

# Check that the script is readable
if [[ ! -r "$script" ]]; then
    echo "error: script is not readable: $script"
    exit 1
fi

# Check that the script is a valid argivo script
if ! argivo::check "$script"; then
    exit 1
fi

# Load the script the user wants to run
# shellcheck source=/dev/null
source "$script"

# Load command metadata
argivo::load_annotations

# If no command is provided, execute main if it exists
if (($# == 0)); then
    if declare -F main >/dev/null; then
        main
        exit 0
    fi

    echo "error: no command provided"
    exit 1
fi

# Process the command-line arguments to determine
# which command to execute
while (($# > 0)); do
    # If the first argument is not a command,
    # execute main with all remaining arguments
    if [[ ! "$1" =~ ^- ]]; then
        if declare -F main >/dev/null; then
            main "$@"
            exit 0
        fi

        echo "error: unexpected argument: $1"
        exit 1
    fi

    # Commands must be specified with a leading "-" or "--"
    if [[ ! "$1" =~ ^--?[a-zA-Z_][a-zA-Z0-9_]*$ ]]; then
        echo "error: invalid command syntax: $1"
        exit 1
    fi

    # Raw command to be executed
    raw_cmd="$1"
    shift

    # Command is specified with "--", so we remove the
    # leading dashes to get the command name
    if [[ "$raw_cmd" == --* ]]; then
        cmd="${raw_cmd#--}"

        # Built-in help command for user-defined commands
        if [[ "$cmd" == "help" ]]; then
            argivo::help_user "$@"
            exit 0
        fi

    # Command is specified with "-", so we treat it as an alias
    # in case it matches one of the defined aliases
    elif [[ "$raw_cmd" == -* ]]; then
        alias_name="${raw_cmd#-}"

        # Built-in help command for user-defined commands
        if [[ "$alias_name" == "h" ]]; then
            argivo::help_user "$@"
            exit 0
        fi

        if [[ -n "${ARGIVO_ALIASES[$alias_name]:-}" ]]; then
            cmd="${ARGIVO_ALIASES[$alias_name]}"
        else
            echo "error: unknown command alias: $alias_name"
            exit 1
        fi
    fi

    # Check that the command exists
    if ! declare -F "$cmd" >/dev/null; then
        echo "error: unknown command: $cmd"
        exit 1
    fi

    param_count=0

    # Determine how many arguments the command expects
    if [[ -n "${ARGIVO_PARAMS[$cmd]:-}" ]]; then
        read -r -a params <<< "${ARGIVO_PARAMS[$cmd]}"
        param_count="${#params[@]}"
    fi

    cmd_args=()

    # Collect the arguments for the command based on
    # the number of parameters it expects
    for ((i = 0; i < param_count; i++)); do
        if (($# == 0)); then
            echo "error: missing arguments for command: $cmd"
            echo "usage: $(basename "$script") $(argivo::usage "$cmd")"
            exit 1
        fi

        cmd_args+=("$1")
        shift
    done

    # Execute the command with its arguments
    "$cmd" "${cmd_args[@]}"
done