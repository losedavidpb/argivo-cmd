#!/usr/bin/env bash
#
# argivo - interpreter for argivo scripts

set -Eeuo pipefail

# Check whether the user provided arguments
if (($# == 0)); then
    echo "error: no arguments were provided" >&2
    echo "usage: $0 <script> [args...]" >&2
    exit 1
fi

# Directories for argivo libraries
_argivo_lib="/usr/local/lib/argivo"
_argivo_public_lib="$_argivo_lib/public"
_argivo_private_lib="$_argivo_lib/private"

# Check library directory
if [[ ! -d "$_argivo_lib" ]]; then
    echo "error: library directory not found: $_argivo_lib" >&2
    exit 1
fi

# Check public library directory
if [[ ! -d "$_argivo_public_lib" ]]; then
    echo "error: public library directory not found: $_argivo_public_lib" >&2
    exit 1
fi

# Check private library directory
if [[ ! -d "$_argivo_private_lib" ]]; then
    echo "error: private library directory not found: $_argivo_private_lib" >&2
    exit 1
fi

# Load public libraries
for _lib in "$_argivo_public_lib"/*.bash; do
    if [[ -f "$_lib" && -r "$_lib" ]]; then
        # shellcheck source=/dev/null
        source "$_lib"
    else
        echo "error: $_lib not found or not readable" >&2
        exit 1
    fi
done

# The interpreter includes built-in commands
# that can be used without a user script
case "$1" in
    --version|-v)
        # shellcheck source=/dev/null
        source "$_argivo_private_lib/metadata.bash"
        _argivo::version
        exit 0
        ;;

    --about|-a)
        # shellcheck source=/dev/null
        source "$_argivo_private_lib/metadata.bash"
        _argivo::about
        exit 0
        ;;

    --help|-h)
        # shellcheck source=/dev/null
        source "$_argivo_private_lib/metadata.bash"
        _argivo::help
        exit 0
        ;;

    --check|-c)
        # shellcheck source=/dev/null
        source "$_argivo_private_lib/checker.bash"

        shift
        _argivo::check "$@" --verbose
        exit 0
        ;;
esac

# Get the script to be interpreted
_script="$1"
shift

# Check that the script exists
if [[ ! -f "$_script" ]]; then
    echo "error: script not found: $_script"
    exit 1
fi

# Check that the script is readable
if [[ ! -r "$_script" ]]; then
    echo "error: script is not readable: $_script"
    exit 1
fi

(
    # shellcheck source=/dev/null
    source "$_argivo_private_lib/checker.bash"

    # Check that the script is a valid argivo script
    if ! _argivo::check "$_script"; then
        exit 1
    fi
)

# Load the script the user wants to run
# shellcheck source=/dev/null
source "$_script"

# shellcheck source=/dev/null
source "$_argivo_private_lib/parser.bash"

# Load command metadata
_argivo::load_annotations

# If no command is provided, execute main if it exists
if (($# == 0)); then
    if declare -F main >/dev/null; then
        main
        exit 0
    fi

    echo "error: no command provided"
    exit 1
fi

# Process the command-line arguments to determine
# which command to execute
while (($# > 0)); do
    # If the first argument is not a command,
    # execute main with all remaining arguments
    if [[ ! "$1" =~ ^- ]]; then
        if declare -F main >/dev/null; then
            main "$@"
            exit 0
        fi

        echo "error: unexpected argument: $1"
        exit 1
    fi

    # Commands must be specified with a leading "-" or "--"
    if [[ ! "$1" =~ ^--?[a-zA-Z_][a-zA-Z0-9_]*$ ]]; then
        echo "error: invalid command syntax: $1"
        exit 1
    fi

    # Raw command to be executed
    _raw_cmd="$1"
    shift

    # Command is specified with "--", so we remove the
    # leading dashes to get the command name
    if [[ "$_raw_cmd" == --* ]]; then
        _cmd="${_raw_cmd#--}"

        # Built-in help command for user-defined commands
        if [[ "$_cmd" == "help" ]]; then
            # shellcheck source=/dev/null
            source "$_argivo_private_lib/helper.bash"

            _argivo::help_script "$@"
            exit 0
        fi

    # Command is specified with "-", so we treat it as an alias
    # in case it matches one of the defined aliases
    elif [[ "$_raw_cmd" == -* ]]; then
        _alias_name="${_raw_cmd#-}"

        # Built-in help command for user-defined commands
        if [[ "$_alias_name" == "h" ]]; then
            # shellcheck source=/dev/null
            source "$_argivo_private_lib/helper.bash"

            _argivo::help_script "$@"
            exit 0
        fi

        if [[ -n "${_ARGIVO_ALIASES[$_alias_name]:-}" ]]; then
            _cmd="${_ARGIVO_ALIASES[$_alias_name]}"
        else
            echo "error: unknown command alias: $_alias_name"
            exit 1
        fi
    fi

    # Check that the command exists
    if ! declare -F "$_cmd" >/dev/null; then
        echo "error: unknown command: $_cmd"
        exit 1
    fi

    _param_count=0

    # Determine how many arguments the command expects
    if [[ -n "${_ARGIVO_PARAMS[$_cmd]:-}" ]]; then
        read -r -a _params <<< "${_ARGIVO_PARAMS[$_cmd]}"
        _param_count="${#_params[@]}"
    fi

    _cmd_args=()

    # Collect the arguments for the command based on
    # the number of parameters it expects
    for ((i = 0; i < _param_count; i++)); do
        if (($# == 0)); then
            # shellcheck source=/dev/null
            source "$_argivo_private_lib/helper.bash"

            echo "error: missing arguments for command: $_cmd"
            echo "usage: $(basename "$_script") $(_argivo::usage "$_cmd")"
            exit 1
        fi

        _cmd_args+=("$1")
        shift
    done

    # Execute the command with its arguments
    "$_cmd" "${_cmd_args[@]}"
done